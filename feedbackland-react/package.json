{
  "name": "feedbackland-react",
  "version": "2.8.0",
  "description": "Drop-in React feedback widget. Slide-in drawer or popover; embeds a Feedbackland board via iframe (or your self-hosted instance) and submits feedback through a hosted API.",
  "keywords": [
    "feedback",
    "react",
    "widget",
    "embed",
    "saas",
    "drawer",
    "popover",
    "feedbackland",
    "user-feedback",
    "in-app-feedback"
  ],
  "license": "MIT",
  "author": "Feedbackland",
  "homepage": "https://github.com/feedbackland/feedbackland-react#readme",
  "bugs": {
    "url": "https://github.com/feedbackland/feedbackland-react/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "module": "./dist/feedbackland-react.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/feedbackland-react.js",
      "default": "./dist/feedbackland-react.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feedbackland/feedbackland-react.git"
  },
  "private": false,
  "scripts": {
    "dev": "tsc -b && vite",
    "build": "tsc -b && vite build",
    "build:watch": "vite build --watch",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "penpal": "^7.0.6",
    "react-focus-on": "^3.10.2",
    "react-hook-form": "^7.74.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rollup-preserve-directives": "^1.1.3",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
